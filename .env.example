# PayChangu Environment Configuration
# Copy this to .env.local for local dev (never commit .env.local)
#
# Set PAYCHANGU_MODE to "test" or "live"
# In test mode  → PAYCHANGU_TEST_SECRET_KEY is used
# In live mode  → PAYCHANGU_SECRET_KEY is used

PAYCHANGU_MODE=test

# Live secret key (from PayChangu dashboard → API Keys → Live)
PAYCHANGU_SECRET_KEY=your_live_secret_key_here

# Test secret key (from PayChangu dashboard → API Keys → Test)
PAYCHANGU_TEST_SECRET_KEY=your_test_secret_key_here

# Frontend build-time variable — must match PAYCHANGU_MODE above
VITE_PAYCHANGU_MODE=test

# Set automatically by Netlify — do not override unless testing locally
# URL=https://warmheart.studio
